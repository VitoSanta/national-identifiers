<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>net8.0;net10.0</TargetFrameworks>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <LangVersion>latest</LangVersion>
    <RootNamespace>NationalIdentifiers.Core</RootNamespace>
    <AssemblyName>NationalIdentifiers.Core</AssemblyName>
    <PackageId>NationalIdentifiers.Core</PackageId>
    <Version>1.0.2</Version>
    <Authors>Vito Santanelli</Authors>
    <PackageProjectUrl>https://github.com/VitoSanta/national-identifiers</PackageProjectUrl>
    <RepositoryUrl>https://github.com/VitoSanta/national-identifiers.git</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PublishRepositoryUrl>true</PublishRepositoryUrl>
    <Description>Offline validation of personal tax IDs, VAT numbers and company identifiers across 195 countries and supported territories, with confidence levels and policy decisions.</Description>
    <PackageTags>national-identifiers;tax-id;tin;codice-fiscale;partita-iva;vat;national-identifier;validation;checksum</PackageTags>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <PackageRequireLicenseAcceptance>false</PackageRequireLicenseAcceptance>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <IncludeSymbols>true</IncludeSymbols>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>
  </PropertyGroup>

  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="\" />
    <InternalsVisibleTo Include="NationalIdentifiers.Tests" />
  </ItemGroup>

</Project>
