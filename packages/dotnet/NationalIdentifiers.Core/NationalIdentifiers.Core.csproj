<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>net8.0;net10.0</TargetFrameworks>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <LangVersion>latest</LangVersion>
    <RootNamespace>NationalIdentifiers.Core</RootNamespace>
    <AssemblyName>NationalIdentifiers.Core</AssemblyName>
    <PackageId>NationalIdentifiers.Core</PackageId>
    <Version>0.1.0</Version>
    <Authors>Vito Santanelli</Authors>
    <PackageProjectUrl>https://github.com/VitoSanta/CF</PackageProjectUrl>
    <RepositoryUrl>https://github.com/VitoSanta/CF.git</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PublishRepositoryUrl>true</PublishRepositoryUrl>
    <Description>Local pre-validation of national identifiers for 195 countries, with normalization, format and checksum confidence levels, and accept/warn/block policy decisions.</Description>
    <PackageTags>tax-id;tin;codice-fiscale;partita-iva;vat;national-identifier;validation;checksum</PackageTags>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <PackageRequireLicenseAcceptance>false</PackageRequireLicenseAcceptance>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <IncludeSymbols>true</IncludeSymbols>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>
  </PropertyGroup>

  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="\" />
  </ItemGroup>

</Project>
