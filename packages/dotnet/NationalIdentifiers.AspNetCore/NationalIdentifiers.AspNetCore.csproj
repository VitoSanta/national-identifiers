<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>net8.0;net10.0</TargetFrameworks>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <LangVersion>latest</LangVersion>
    <RootNamespace>NationalIdentifiers.AspNetCore</RootNamespace>
    <AssemblyName>NationalIdentifiers.AspNetCore</AssemblyName>
    <PackageId>NationalIdentifiers.AspNetCore</PackageId>
    <Version>1.0.1</Version>
    <Authors>Vito Santanelli</Authors>
    <PackageProjectUrl>https://github.com/VitoSanta/national-identifiers</PackageProjectUrl>
    <RepositoryUrl>https://github.com/VitoSanta/national-identifiers.git</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PublishRepositoryUrl>true</PublishRepositoryUrl>
    <Description>ASP.NET Core integration for policy-aware local pre-validation of national identifiers in web APIs.</Description>
    <PackageTags>national-identifiers;tax-id;tin;codice-fiscale;partita-iva;aspnetcore;validation</PackageTags>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <PackageRequireLicenseAcceptance>false</PackageRequireLicenseAcceptance>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <IncludeSymbols>true</IncludeSymbols>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>
  </PropertyGroup>

  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="\" />
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
    <ProjectReference Include="..\NationalIdentifiers.Core\NationalIdentifiers.Core.csproj" />
  </ItemGroup>

</Project>
