{
  "name": "tax-id-workspace",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "demo": "ng build tax-id && ng serve manual-test",
    "build:demo": "ng build tax-id && ng build manual-test",
    "build": "ng build tax-id",
    "watch": "ng build --watch --configuration development",
    "sources:generate": "node scripts/generate-rule-source-catalogue.mjs",
    "sources:check": "node scripts/generate-rule-source-catalogue.mjs --check",
    "test": "npm run build && node --test tests/node/*.test.mjs",
    "test:angular": "ng test tax-id --watch=false",
    "benchmark": "npm run build && node scripts/measure-performance.mjs",
    "benchmark:dotnet": "dotnet run --project packages/dotnet/NationalIdentifiers.Benchmarks/NationalIdentifiers.Benchmarks.csproj --configuration Release",
    "verify": "npm test && npm run test:angular && npm run build:demo"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "dependencies": {
    "@angular/common": "^20.3.0",
    "@angular/compiler": "^20.3.0",
    "@angular/core": "^20.3.0",
    "@angular/forms": "^20.3.0",
    "@angular/platform-browser": "^20.3.0",
    "@angular/router": "^20.3.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular/build": "^20.3.27",
    "@angular/cli": "^20.3.27",
    "@angular/compiler-cli": "^20.3.0",
    "@types/jasmine": "~5.1.0",
    "jasmine-core": "~5.9.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "ng-packagr": "^20.3.0",
    "typescript": "~5.9.2"
  }
}
