{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/vitosantanelli/tax-id/rule-sources.schema.json",
  "title": "National identifier rule-source catalogue",
  "type": "array",
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": [
      "country",
      "jurisdictionType",
      "identifierType",
      "identifierName",
      "validationLevel",
      "authority",
      "sourceUrl",
      "sourceType",
      "accessedAt",
      "lastReviewedAt",
      "provenanceStatus",
      "limitations"
    ],
    "properties": {
      "country": {
        "type": "string",
        "pattern": "^[A-Z]{2}$"
      },
      "identifierType": {
        "enum": ["tax_id_person", "vat", "tax_id_company"]
      },
      "jurisdictionType": {
        "enum": ["state", "territory"]
      },
      "identifierName": {
        "type": "string",
        "minLength": 2
      },
      "validationLevel": {
        "enum": ["format", "checksum", "not_applicable"]
      },
      "authority": {
        "type": "string",
        "minLength": 3
      },
      "sourceUrl": {
        "type": "string",
        "pattern": "^https://"
      },
      "sourceType": {
        "enum": [
          "tax_authority",
          "legislation",
          "official_specification",
          "intergovernmental",
          "government_registry",
          "government_portal"
        ]
      },
      "accessedAt": {
        "type": "string",
        "format": "date"
      },
      "lastReviewedAt": {
        "type": "string",
        "format": "date"
      },
      "provenanceStatus": {
        "enum": ["verified", "corroborated", "documented_limit"]
      },
      "limitations": {
        "type": "array",
        "items": {
          "type": "string",
          "minLength": 3
        }
      }
    }
  }
}
